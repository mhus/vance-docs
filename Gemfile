source "https://rubygems.org"

# GitHub Pages build environment. Pinning to the github-pages gem keeps
# local previews in sync with the build that runs on github.io.
gem "github-pages", group: :jekyll_plugins

gem "jekyll-remote-theme"
gem "jekyll-seo-tag"
gem "jekyll-sitemap"

# Required on Apple Silicon / newer Rubies.
gem "webrick", "~> 1.8"
